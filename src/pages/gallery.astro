---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrustBadge from "../components/TrustBadge.astro";

const PHONE_RAW = "+14168387519";
const PHONE     = "+1 (416) 838-7519";

/**
 * Gallery items — replace src with real photo paths once you have them.
 * All captions are from the original site content (preserved verbatim).
 */
const galleryItems = [
  { src: "/gallery/panel-upgrade-01.jpg",     caption: "Electrical panel upgrade — Toronto residential",                 category: "Panel Upgrades" },
  { src: "/gallery/panel-upgrade-02.jpg",     caption: "200A service upgrade completed to code",                         category: "Panel Upgrades" },
  { src: "/gallery/commercial-wiring-01.jpg", caption: "Commercial wiring installation — GTA office",                    category: "Commercial" },
  { src: "/gallery/commercial-wiring-02.jpg", caption: "Three-phase commercial electrical installation",                  category: "Commercial" },
  { src: "/gallery/ev-charger-01.jpg",        caption: "Level 2 EV charger installation — Toronto home garage",          category: "EV Chargers" },
  { src: "/gallery/ev-charger-02.jpg",        caption: "EV charging station installed for commercial fleet",              category: "EV Chargers" },
  { src: "/gallery/lighting-01.jpg",          caption: "LED lighting upgrade — residential kitchen",                      category: "Lighting" },
  { src: "/gallery/lighting-02.jpg",          caption: "Recessed lighting installation — GTA home renovation",            category: "Lighting" },
  { src: "/gallery/switchboard-01.jpg",       caption: "Switchboard upgrade — replaced Federal Pacific panel",            category: "Panel Upgrades" },
  { src: "/gallery/outdoor-01.jpg",           caption: "Outdoor electrical installation — patio and landscape lighting",  category: "Residential" },
  { src: "/gallery/inspection-01.jpg",        caption: "Electrical safety inspection — pre-purchase home assessment",     category: "Inspections" },
  { src: "/gallery/residential-01.jpg",       caption: "Complete residential rewire — Etobicoke",                        category: "Residential" },
];

const categories = [...new Set(galleryItems.map(i => i.category))];
---

<BaseLayout
  title="Gallery | Eclipse Electrical Services Toronto GTA"
  description="Browse Eclipse Electrical Services' project gallery — panel upgrades, EV charger installations, commercial wiring, lighting, and more across Toronto and the GTA."
  currentPath="/gallery"
>

<section class="page-banner">
  <h1>Our Work</h1>
  <p>A selection of residential and commercial electrical projects completed by our team across Toronto &amp; GTA.</p>
</section>

<TrustBadge />

<section class="gallery-section" aria-label="Project gallery">
  <div class="gallery-inner">
    <div class="section-label">Project Gallery</div>
    <h2 class="section-h2">Recent Electrical Projects</h2>
    <p class="gallery-intro">Every photo represents a job completed safely, on time, and to the highest standard of workmanship. Our licensed Master Electricians take pride in every project — big or small.</p>

    <!-- Category Filter (JS-powered) -->
    <div class="gallery-filters" role="group" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">All Projects</button>
      {categories.map(cat => (
        <button class="filter-btn" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="gallery-grid" id="gallery-grid">
      {galleryItems.map((item, i) => (
        <figure class="gallery-item" data-category={item.category}>
          <div class="gallery-img-wrap">
            <img
              src={item.src}
              alt={item.caption}
              width="600"
              height="400"
              loading={i < 4 ? "eager" : "lazy"}
              decoding="async"
            />
            <div class="gallery-overlay" aria-hidden="true">
              <span class="gallery-cat">{item.category}</span>
            </div>
          </div>
          <figcaption>{item.caption}</figcaption>
        </figure>
      ))}
    </div>

    <div class="gallery-cta">
      <p>Interested in what we can do for your home or business?</p>
      <div class="gallery-cta-btns">
        <a href="/contact" class="btn-primary">Get a Free Estimate</a>
        <a href={`tel:${PHONE_RAW}`} class="btn-secondary">Call {PHONE}</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .gallery-section { padding: 5rem 2rem; background: var(--off-white); }
  .gallery-inner { max-width: 1100px; margin: 0 auto; }
  .gallery-intro { font-size: .97rem; line-height: 1.8; color: var(--mid); max-width: 680px; margin-bottom: 2.5rem; }

  /* Filters */
  .gallery-filters { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 2.5rem; }
  .filter-btn {
    padding: .45rem 1rem; font-size: .78rem; font-weight: 600;
    letter-spacing: .06em; text-transform: uppercase;
    background: #fff; border: 1.5px solid rgba(0,0,0,.12);
    border-radius: 3px; cursor: pointer; color: var(--mid);
    transition: all .15s;
  }
  .filter-btn:hover,
  .filter-btn.active { background: var(--blue); border-color: var(--blue); color: #fff; }

  /* Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1.5rem;
  }

  .gallery-item.hidden { display: none; }

  .gallery-img-wrap {
    position: relative; overflow: hidden; border-radius: 6px;
    background: var(--cream); aspect-ratio: 3/2;
  }
  .gallery-img-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .35s ease;
    display: block;
  }
  .gallery-item:hover .gallery-img-wrap img { transform: scale(1.04); }

  .gallery-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,.55) 0%, transparent 50%);
    opacity: 0; transition: opacity .25s;
    display: flex; align-items: flex-end; padding: 1rem;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-cat {
    font-size: .68rem; font-weight: 700; letter-spacing: .15em;
    text-transform: uppercase; color: rgba(255,255,255,.9);
    background: rgba(118,173,213,.7); padding: .2rem .6rem; border-radius: 2px;
  }

  figcaption {
    font-size: .8rem; color: var(--mid); line-height: 1.5;
    padding: .65rem .25rem 0;
  }

  /* CTA */
  .gallery-cta { margin-top: 4rem; text-align: center; }
  .gallery-cta p { font-size: 1rem; color: var(--mid); margin-bottom: 1.25rem; font-weight: 500; }
  .gallery-cta-btns { display: flex; align-items: center; justify-content: center; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 900px) { .gallery-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 600px) {
    .gallery-section { padding: 3rem 1.25rem; }
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const buttons  = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const items    = document.querySelectorAll<HTMLElement>(".gallery-item");

  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter ?? "all";

      buttons.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");

      items.forEach(item => {
        if (filter === "all" || item.dataset.category === filter) {
          item.classList.remove("hidden");
        } else {
          item.classList.add("hidden");
        }
      });
    });
  });
</script>
