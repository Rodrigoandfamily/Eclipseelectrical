---
import BaseLayout from "../layouts/BaseLayout.astro";
import TrustBadge from "../components/TrustBadge.astro";

const PHONE_RAW = "+14168387519";
const PHONE     = "+1 (416) 838-7519";
---

<BaseLayout
  title="About Eclipse Electrical Services | Licensed Electricians Toronto GTA"
  description="Learn about Eclipse Electrical Services — licensed Master Electricians serving Toronto and the GTA since 1999. Residential, commercial, and emergency electrical work."
  currentPath="/about"
>

<section class="page-banner">
  <h1>About Us</h1>
  <p>Toronto's trusted Master Electricians — licensed, insured, and dedicated to excellence since 1999.</p>
</section>

<TrustBadge />

<section class="about-section">
  <div class="about-inner">

    <div class="about-text">
      <div class="section-label">Who We Are</div>
      <h2 class="section-h2">Eclipse Electrical Services Ltd</h2>

      <p>Eclipse Electrical Services is your local leading electrical contractor in Toronto – GTA. We are fully trained and certified Master Electricians specializing in all phases of electrical work — from wiring, installation, and repair to maintenance and upgrades for both residential and commercial properties.</p>

      <p>Our team brings decades of combined experience to every project. Whether you need a single light fixture installed or a full commercial fit-out, we approach every job with the same professionalism, attention to detail, and commitment to doing it right the first time.</p>

      <h3>Our Mission</h3>
      <p>To provide Toronto and GTA homeowners and businesses with safe, reliable, and competitively priced electrical services — delivered on time, on budget, and to the highest standards of workmanship.</p>

      <h3>Why Choose Eclipse?</h3>
      <ul class="about-list">
        <li><strong>Licensed &amp; Insured</strong> — All work performed by certified Master Electricians, fully licensed and insured in Ontario.</li>
        <li><strong>24-Hour Emergency Service</strong> — Electrical emergencies don't keep business hours. Neither do we.</li>
        <li><strong>Fast Response</strong> — We show up on time and get the job done efficiently, every time.</li>
        <li><strong>Done Right the First Time</strong> — We take pride in quality workmanship and stand behind every job we complete.</li>
        <li><strong>Free Estimates</strong> — No-obligation quotes for all residential and commercial projects.</li>
        <li><strong>Competitive Pricing</strong> — Quality work at a fair price. We'll beat most comparable quotes.</li>
      </ul>

      <div class="about-cta">
        <a href="/contact" class="btn-primary">Get a Free Estimate</a>
        <a href={`tel:${PHONE_RAW}`} class="btn-secondary">Call {PHONE}</a>
      </div>
    </div>

    <aside class="about-sidebar">
      <div class="sidebar-card">
        <img src="/logo.png" alt="Eclipse Electrical Services Ltd" width="80" height="80" loading="lazy" />
        <h4>Eclipse Electrical Services Ltd</h4>
        <p>Serving Toronto &amp; GTA</p>
        <div class="sidebar-stats">
          <div class="stat"><span>25+</span><label>Years Experience</label></div>
          <div class="stat"><span>24/7</span><label>Emergency Service</label></div>
          <div class="stat"><span>100%</span><label>Licensed &amp; Insured</label></div>
        </div>
        <div class="sidebar-hours">
          <h5>Business Hours</h5>
          <div class="sh-row"><span>Mon – Fri</span><span>8am – 8pm</span></div>
          <div class="sh-row"><span>Saturday</span><span>8am – 8pm</span></div>
          <div class="sh-row"><span>Sunday</span><span>Closed</span></div>
        </div>
        <a href="/contact" class="btn-primary" style="width:100%;text-align:center;display:block;">Book a Call</a>
      </div>
    </aside>

  </div>
</section>

</BaseLayout>

<style>
  .about-section { padding: 5rem 2rem; background: var(--off-white); }
  .about-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: start;
  }
  .about-text p { font-size: .97rem; line-height: 1.8; color: var(--mid); margin-bottom: 1.25rem; }
  .about-text h3 { font-family: "Montserrat",sans-serif; font-weight: 800; font-size: 1.05rem; color: var(--ink); margin: 1.75rem 0 .6rem; }
  .about-list { list-style: none; display: flex; flex-direction: column; gap: .75rem; margin-bottom: 1.5rem; }
  .about-list li { font-size: .9rem; line-height: 1.7; color: var(--mid); padding-left: 1.25rem; position: relative; }
  .about-list li::before { content: "✓"; position: absolute; left: 0; color: var(--blue-dark); font-weight: 700; }
  .about-list li strong { color: var(--ink); }
  .about-cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }

  /* Sidebar */
  .sidebar-card {
    background: #fff; border-radius: 8px; padding: 2rem;
    border: 1px solid rgba(0,0,0,.07); text-align: center;
    position: sticky; top: 120px;
  }
  .sidebar-card img { border-radius: 50%; border: 3px solid var(--blue); margin-bottom: .85rem; }
  .sidebar-card h4 { font-family: "Montserrat",sans-serif; font-weight: 900; font-size: .95rem; color: var(--ink); margin-bottom: .2rem; }
  .sidebar-card > p { font-size: .82rem; color: var(--mid); margin-bottom: 1.5rem; }
  .sidebar-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: .75rem; margin-bottom: 1.5rem; }
  .stat span { display: block; font-family: "Montserrat",sans-serif; font-weight: 900; font-size: 1.4rem; color: var(--blue-dark); }
  .stat label { font-size: .65rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--mid); }
  .sidebar-hours { text-align: left; margin-bottom: 1.5rem; }
  .sidebar-hours h5 { font-family: "Montserrat",sans-serif; font-weight: 800; font-size: .72rem; letter-spacing: .15em; text-transform: uppercase; color: var(--mid); margin-bottom: .65rem; }
  .sh-row { display: flex; justify-content: space-between; font-size: .82rem; color: var(--mid); border-bottom: 1px solid rgba(0,0,0,.06); padding-bottom: .4rem; margin-bottom: .4rem; }
  .sh-row span:last-child { font-weight: 600; color: var(--ink); }

  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .sidebar-card { position: static; }
    .about-section { padding: 3rem 1.25rem; }
  }
</style>
