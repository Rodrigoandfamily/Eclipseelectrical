---
import BaseLayout from "../layouts/BaseLayout.astro";
const PHONE_RAW = "+14168387519";
const PHONE = "+1 (416) 838-7519";
---
<BaseLayout
  title="Thank You | Eclipse Electrical Services"
  description="Thank you for contacting Eclipse Electrical Services. We will be in touch shortly."
  currentPath="/thank-you"
>

<section class="ty-wrap">
  <div class="ty-card">
    <div class="ty-icon">✅</div>
    <h1>Message Sent!</h1>
    <p>Thank you for contacting <strong>Eclipse Electrical Services</strong>. We've received your request and will be in touch within 2–4 business hours.</p>
    <p class="ty-urgent">For urgent or emergency electrical issues, call us directly:</p>
    <a href={`tel:${PHONE_RAW}`} class="ty-phone">📞 {PHONE}</a>
    <a href="/" class="ty-home">← Back to Home</a>
  </div>
</section>

</BaseLayout>

<style>
.ty-wrap{min-height:60vh;display:flex;align-items:center;justify-content:center;padding:4rem 1.5rem;background:#F4F1EC}
.ty-card{background:#fff;border-radius:10px;padding:3rem 2.5rem;max-width:540px;width:100%;text-align:center;box-shadow:0 8px 40px rgba(0,0,0,.1);border-top:4px solid #4e8ab5}
.ty-icon{font-size:3rem;margin-bottom:1rem}
.ty-card h1{font-family:"Montserrat",sans-serif;font-weight:900;font-size:2rem;color:#1A1A1A;margin-bottom:1rem}
.ty-card p{font-size:.97rem;line-height:1.75;color:#5a5a5a;margin-bottom:1rem}
.ty-urgent{font-weight:600;color:#1A1A1A}
.ty-phone{display:inline-block;margin:1rem 0;padding:.85rem 2rem;background:#C0392B;color:#fff;font-family:"Montserrat",sans-serif;font-weight:700;font-size:.95rem;border-radius:4px;text-decoration:none;transition:background .18s}
.ty-phone:hover{background:#a93226}
.ty-home{display:block;margin-top:1.25rem;font-size:.88rem;color:#4e8ab5;text-decoration:none;font-weight:600}
.ty-home:hover{text-decoration:underline}
</style>
