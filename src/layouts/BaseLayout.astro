---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  currentPath?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  currentPath = "/",
} = Astro.props;

const SITE_URL = "https://www.eclipseelectricalservices.ca";
const PHONE   = "+1 (416) 838-7519";
const PHONE_RAW = "+14168387519";
const EMAIL   = "info@eclipseelectricalservices.ca";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Electrician"],
  "name": "Eclipse Electrical Services Ltd",
  "image": `${SITE_URL}/logo.png`,
  "url": SITE_URL,
  "telephone": PHONE,
  "email": EMAIL,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Toronto",
    "addressRegion": "ON",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.6532,
    "longitude": -79.3832
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "08:00",
      "closes": "20:00"
    }
  ],
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": 43.6532,
      "longitude": -79.3832
    },
    "geoRadius": "50000"
  },
  "description": "Licensed Master Electricians serving Toronto and GTA. Residential & commercial electrical services, EV charger installation, 24-hour emergency service.",
  "priceRange": "$$",
  "currenciesAccepted": "CAD",
  "paymentAccepted": "Cash, Credit Card, Cheque",
  "sameAs": [
    "https://www.facebook.com/eclipseelectricalservicesltd/"
  ]
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${SITE_URL}${ogImage}`} />
  <meta property="og:url" content={`${SITE_URL}${currentPath}`} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_CA" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${SITE_URL}${ogImage}`} />

  <!-- Canonical -->
  <link rel="canonical" href={`${SITE_URL}${currentPath}`} />

  <title>{title}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Open+Sans:wght@400;500;600&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={schema} />

  <!-- Global Styles -->
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --off-white: #F4F1EC;
      --cream:     #EDE9E1;
      --red:       #C0392B;
      --blue:      #76ADD5;
      --blue-dark: #4e8ab5;
      --ink:       #1A1A1A;
      --mid:       #5a5a5a;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: "Open Sans", sans-serif;
      background: var(--off-white);
      padding-top: 106px; /* 34px topbar + 72px nav */
    }

    @media (max-width: 768px) {
      body { padding-top: 62px; }
    }

    /* ── TOPBAR ── */
    .topbar {
      background: var(--blue);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 34px;
    }
    .topbar-left { display: flex; align-items: center; gap: 1.2rem; }
    .topbar span {
      font-size: .68rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: rgba(255,255,255,.85);
      display: flex;
      align-items: center;
      gap: .35rem;
    }
    .topbar span b { color: #fff; font-weight: 600; }
    .dot-sep { color: rgba(255,255,255,.4); }
    .avail-pill {
      display: flex;
      align-items: center;
      gap: .4rem;
      background: rgba(255,255,255,.18);
      border-radius: 20px;
      padding: .15rem .7rem;
      font-size: .62rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: #fff;
    }
    .green-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #4ade80;
      animation: blink 2s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{ opacity:1 } 50%{ opacity:.3 } }

    /* ── NAV ── */
    .nav-main {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 72px;
      background: var(--off-white);
      border-bottom: 1px solid rgba(0,0,0,.08);
    }
    .logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; z-index: 101; }
    .logo img { height: 52px; width: 52px; object-fit: cover; border-radius: 50%; border: 2px solid var(--blue); }
    .nav-links { display: flex; align-items: center; gap: .2rem; }
    .nav-links a {
      font-size: .82rem;
      font-weight: 500;
      color: var(--ink);
      text-decoration: none;
      padding: .45rem .85rem;
      border-radius: 3px;
      transition: background .15s, color .15s;
    }
    .nav-links a:hover { background: var(--cream); }
    .nav-links a.active { background: var(--blue); color: #fff; }
    .nav-right { display: flex; align-items: center; gap: .75rem; }
    .phone-link {
      display: flex;
      align-items: center;
      gap: .45rem;
      font-size: .88rem;
      font-weight: 600;
      color: var(--ink);
      text-decoration: none;
      transition: color .15s;
    }
    .phone-link:hover { color: var(--blue-dark); }
    .phone-link svg { width: 14px; height: 14px; fill: var(--mid); }
    .divider { width: 1px; height: 20px; background: rgba(0,0,0,.12); }
    .btn-quote {
      font-family: "Open Sans", sans-serif;
      font-weight: 700;
      font-size: .8rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding: .55rem 1.3rem;
      background: var(--red);
      color: #fff;
      border: none;
      border-radius: 3px;
      cursor: pointer;
      text-decoration: none;
      transition: background .15s;
    }
    .btn-quote:hover { background: #a93226; }
    .ham {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 6px;
      z-index: 101;
      background: none;
      border: none;
    }
    .ham span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--ink);
      border-radius: 2px;
      transition: all .25s;
      transform-origin: center;
    }
    .ham.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .ham.open span:nth-child(2) { opacity: 0; }
    .ham.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── TICKER ── */
    .ticker {
      background: var(--cream);
      border-top: 1px solid rgba(0,0,0,.07);
      border-bottom: 1px solid rgba(0,0,0,.07);
      overflow: hidden;
      height: 36px;
      display: flex;
      align-items: center;
    }
    .ticker-track {
      display: flex;
      align-items: center;
      white-space: nowrap;
      animation: scroll 28s linear infinite;
    }
    .ticker-track:hover { animation-play-state: paused; }
    @keyframes scroll { 0%{ transform: translateX(0) } 100%{ transform: translateX(-50%) } }
    .ticker-item {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: 0 2rem;
      font-size: .72rem;
      font-weight: 600;
      color: var(--mid);
      letter-spacing: .06em;
      white-space: nowrap;
    }
    .ticker-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .ticker-dot.r { background: var(--red); }
    .ticker-dot.b { background: var(--blue); }
    .ticker-sep { color: rgba(0,0,0,.15); font-size: 1rem; }

    /* ── PAGE BANNER (inner pages) ── */
    .page-banner { background: var(--blue); padding: 3.5rem 2rem; text-align: center; }
    .page-banner h1 {
      font-family: "Montserrat", sans-serif;
      font-weight: 900;
      font-size: clamp(2rem,5vw,3rem);
      color: #fff;
      letter-spacing: -.02em;
      margin-bottom: .5rem;
    }
    .page-banner p { font-size: .95rem; color: rgba(255,255,255,.75); max-width: 540px; margin: 0 auto; }

    /* ── SHARED SECTION STYLES ── */
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1rem;
    }
    .section-label::before { content: ""; display: block; width: 18px; height: 2px; background: var(--red); }
    .section-h2 {
      font-family: "Montserrat", sans-serif;
      font-weight: 900;
      font-size: clamp(1.8rem,4vw,2.8rem);
      color: var(--ink);
      margin-bottom: 1rem;
      letter-spacing: -.02em;
    }

    /* ── FOOTER ── */
    .footer { background: var(--ink); color: rgba(255,255,255,.7); padding: 4rem 2rem 0; }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .footer-brand img { height: 56px; width: 56px; object-fit: cover; border-radius: 50%; border: 2px solid var(--blue); margin-bottom: 1rem; }
    .footer-brand p { font-size: .85rem; line-height: 1.7; color: rgba(255,255,255,.5); max-width: 240px; margin-bottom: 1.25rem; }
    .footer-social { display: flex; gap: .6rem; }
    .footer-social a {
      width: 34px; height: 34px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,.15);
      display: flex; align-items: center; justify-content: center;
      transition: border-color .18s, background .18s;
      text-decoration: none;
    }
    .footer-social a:hover { border-color: var(--blue); background: rgba(118,173,213,.15); }
    .footer-social svg { width: 14px; height: 14px; fill: rgba(255,255,255,.6); }
    .footer-col h4 {
      font-family: "Montserrat", sans-serif;
      font-weight: 800;
      font-size: .75rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 1.1rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .55rem; }
    .footer-col ul li a { font-size: .83rem; color: rgba(255,255,255,.5); text-decoration: none; transition: color .15s; }
    .footer-col ul li a:hover { color: var(--blue); }
    .footer-hours { display: flex; flex-direction: column; gap: .55rem; }
    .footer-hour-row {
      display: flex; justify-content: space-between;
      font-size: .83rem; color: rgba(255,255,255,.5);
      border-bottom: 1px solid rgba(255,255,255,.05);
      padding-bottom: .45rem;
    }
    .footer-hour-row span:last-child { color: rgba(255,255,255,.8); font-weight: 500; }
    .footer-emergency {
      margin-top: .5rem;
      display: flex; align-items: center; gap: .4rem;
      font-size: .75rem; color: var(--blue); font-weight: 600; letter-spacing: .06em;
    }
    .footer-emergency::before {
      content: '';
      width: 7px; height: 7px; border-radius: 50%;
      background: #4ade80; flex-shrink: 0;
      animation: blink 2s ease-in-out infinite;
    }
    .footer-bottom {
      max-width: 1100px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.25rem 0;
      font-size: .72rem; color: rgba(255,255,255,.3);
      flex-wrap: wrap; gap: .5rem;
    }
    .footer-bottom a { color: rgba(255,255,255,.3); text-decoration: none; transition: color .15s; }
    .footer-bottom a:hover { color: rgba(255,255,255,.6); }
    .footer-bottom-links { display: flex; gap: 1.5rem; }

    /* ── MOBILE OVERLAY & DRAWER ── */
    .overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.5); z-index: 1998;
    }
    .overlay.open { display: block; }

    .mobile-nav {
      display: none; position: fixed; top: 0; right: 0;
      width: min(300px,82vw);
      height: 100vh; height: 100dvh;
      background: var(--off-white); z-index: 1999;
      flex-direction: column;
      border-left: 3px solid var(--blue);
      box-shadow: -4px 0 30px rgba(0,0,0,.2);
      overflow: hidden;
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    .mobile-nav.open { display: flex; }
    .nav-close {
      position: absolute; top: .85rem; right: 1rem;
      background: rgba(0,0,0,.06); border: none;
      font-size: 2.4rem; line-height: 1; color: var(--ink);
      cursor: pointer; z-index: 10;
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
    }
    .mobile-links {
      flex: 1 1 auto; overflow-y: auto;
      padding: 4.5rem 1.5rem .5rem;
      display: flex; flex-direction: column; gap: 0;
      min-height: 0;
    }
    .mobile-links a {
      font-size: 1rem; font-weight: 600; color: var(--ink);
      text-decoration: none; padding: .9rem .5rem;
      border-bottom: 1px solid rgba(0,0,0,.08);
      display: block; transition: color .15s;
    }
    .mobile-links a:last-child { border-bottom: none; }
    .mobile-links a:hover { color: var(--blue-dark); }
    .mobile-links a.active { color: var(--blue-dark); font-weight: 700; }
    .mobile-cta-bottom {
      flex: 0 0 auto;
      display: flex; flex-direction: column; gap: .5rem;
      padding: .75rem 1.25rem max(1.25rem, env(safe-area-inset-bottom));
      border-top: 1.5px solid rgba(0,0,0,.1);
      background: var(--off-white);
    }
    .mobile-cta-bottom a {
      display: block; width: 100%; text-align: center;
      padding: .85rem 1rem; font-size: .9rem; font-weight: 700;
      border-radius: 4px; text-decoration: none;
    }
    .m-call { background: var(--cream) !important; color: var(--blue-dark) !important; border: 1.5px solid var(--blue) !important; }
    .m-quote { background: var(--red) !important; color: #fff !important; border: none !important; }

    /* ── FIXED HEADER ── */
    #site-header { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; }
    header { box-shadow: 0 2px 16px rgba(0,0,0,.10); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .topbar { display: none; }
      .nav-main { padding: 0 1.25rem; height: 62px; }
      .nav-links, .nav-right { display: none; }
      .ham { display: flex; }
      .footer { padding: 3rem 1.25rem 0; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .footer-brand { grid-column: 1/-1; }
      .footer-bottom { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 480px) {
      .footer-inner { grid-template-columns: 1fr; }
    }

    /* ── SHARED BUTTON STYLES ── */
    .btn-primary {
      padding: .85rem 1.8rem;
      background: var(--red); color: #fff;
      font-family: "Montserrat", sans-serif; font-weight: 700;
      font-size: .82rem; letter-spacing: .08em; text-transform: uppercase;
      border: none; border-radius: 3px; cursor: pointer;
      text-decoration: none;
      transition: background .18s, transform .12s;
      display: inline-block;
    }
    .btn-primary:hover { background: #a93226; transform: translateY(-1px); }
    .btn-secondary {
      padding: .85rem 1.8rem;
      background: rgba(255,255,255,.88); color: var(--blue-dark);
      font-family: "Montserrat", sans-serif; font-weight: 700;
      font-size: .82rem; letter-spacing: .08em; text-transform: uppercase;
      border: 2px solid var(--blue); border-radius: 3px; cursor: pointer;
      text-decoration: none;
      transition: background .18s, color .18s;
      display: inline-block;
    }
    .btn-secondary:hover { background: var(--blue); color: #fff; }
  </style>
</head>
<body>

  <!-- ── FIXED HEADER ── -->
  <div id="site-header">
    <div class="topbar">
      <div class="topbar-left">
        <span>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="2.5" stroke-linecap="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18z"/>
          </svg>
          <b>+1 (416) 838-7519</b>
        </span>
        <span class="dot-sep">·</span>
        <span>Mon–Sat <b>8am – 8pm</b></span>
        <span class="dot-sep">·</span>
        <span>24-Hour Emergency Service</span>
      </div>
      <div class="avail-pill"><span class="green-dot"></span>Taking new jobs</div>
    </div>

    <header>
      <div class="nav-main">
        <a href="/" class="logo" aria-label="Eclipse Electrical Services – Home">
          <img src="/logo.png" alt="Eclipse Electrical Services Ltd" width="52" height="52" />
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a href="/" class={currentPath === "/" ? "active" : ""}>Home</a>
          <a href="/services" class={currentPath === "/services" ? "active" : ""}>Services</a>
          <a href="/about" class={currentPath === "/about" ? "active" : ""}>About Us</a>
          <a href="/gallery" class={currentPath === "/gallery" ? "active" : ""}>Gallery</a>
          <a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Contact</a>
        </nav>
        <div class="nav-right">
          <a href={`tel:${PHONE_RAW}`} class="phone-link" aria-label="Call us">
            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.14 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.05 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 18z"/></svg>
            +1 (416) 838-7519
          </a>
          <div class="divider"></div>
          <a href="/contact" class="btn-quote">Free Estimate</a>
        </div>
        <button class="ham" id="hamBtn" aria-label="Open menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>

      <!-- Ticker -->
      <div class="ticker" aria-hidden="true">
        <div class="ticker-track">
          <span class="ticker-item"><span class="ticker-dot r"></span> Licensed &amp; Insured</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot b"></span> Residential &amp; Commercial</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot r"></span> 24-Hour Emergency</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot b"></span> EV Charger Installation</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot r"></span> Toronto &amp; GTA</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot b"></span> Master Electricians</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot r"></span> Free Estimates</span><span class="ticker-sep">|</span>
          <!-- duplicate set for seamless loop -->
          <span class="ticker-item"><span class="ticker-dot r"></span> Licensed &amp; Insured</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot b"></span> Residential &amp; Commercial</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot r"></span> 24-Hour Emergency</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot b"></span> EV Charger Installation</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot r"></span> Toronto &amp; GTA</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot b"></span> Master Electricians</span><span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-dot r"></span> Free Estimates</span><span class="ticker-sep">|</span>
        </div>
      </div>
    </header>
  </div><!-- /site-header -->

  <!-- Mobile overlay -->
  <div class="overlay" id="overlay"></div>

  <!-- Mobile drawer -->
  <nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation" aria-hidden="true">
    <button class="nav-close" id="navClose" aria-label="Close menu">×</button>
    <div class="mobile-links">
      <a href="/" class={currentPath === "/" ? "active" : ""}>Home</a>
      <a href="/services" class={currentPath === "/services" ? "active" : ""}>Services</a>
      <a href="/about" class={currentPath === "/about" ? "active" : ""}>About Us</a>
      <a href="/gallery" class={currentPath === "/gallery" ? "active" : ""}>Gallery</a>
      <a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Contact</a>
